# Copy this file to .env and fill in the values for local development.
# Never commit .env — it is listed in .gitignore.

PORT=3000

# ── Option A: single connection URL (takes priority over Option B) ──────────
# DATABASE_URL=mysql://root:password@127.0.0.1:3306/event_management

# ── Option B: individual connection fields ───────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=event_management

# Set to "true" to enable TLS for the DB connection
DB_SSL=false

# Auth
JWT_SECRET=change_me_in_production

# Google OAuth (optional)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback
GOOGLE_AUTH_SUCCESS_REDIRECT=http://localhost:3000

# Session
SESSION_SECRET=change_me_in_production

# SMTP (optional – used by emailService.js)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
